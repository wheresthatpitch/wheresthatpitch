<h1><%= @county.name %></h1>
<div class="row">
  <div class="col">
    <%- if @county.clubs.empty? %>
      <p>There are no clubs here yet</p>
    <%- else %>
      <div class="list-group">
        <%- @county.clubs.each do |club| %>
          <%= link_to club_path(province: @county.province.slug, county: @county.slug, club: club.slug), class: "list-group-item list-group-item-action" do %>
            <span class="badge bg-primary"><%= @county.clubs.count %></span> <%= club.name %>
        <%- end %>
      <%- end %>
      </div>
    <%- end %>
  </div>
  <div class="col">
    <%- if @county.pitches.empty? %>
      <p>There are no pitches here yet</p>
    <%- else %>
      <div class="list-group">
        <%- @county.pitches.each do |pitch| %>
          <%= link_to pitch_path(province: @county.province.slug, county: @county.slug, pitch: pitch.slug), class: "list-group-item list-group-item-action" do %>
            <span class="badge bg-primary"><%= @county.pitches.count %></span> <%= @county.name %>
        <%- end %>
      <%- end %>
      </div>
    <%- end %>
  </div>
</div>
