<div class="row">
  <div class="col">
    <p>Drill down through each section</p>
  </div>
  <div class="col">
    <div class="list-group">
      <%- @provinces.each do |province| %>
        <%= link_to province.name, province_path(province.slug), class: "list-group-item list-group-item-action" %>
      <%- end %>
    </div>
  </div>
</div>
